# Managed by Ansible — do not edit by hand

# Database
DATABASE_URL=postgresql://brenso:{{ postgres_password }}@postgres:5432/brenso
POSTGRES_PASSWORD={{ postgres_password }}

# Session
SESSION_SECRET={{ session_secret }}

# Coach seed (used on first migration)
COACH_NAME={{ coach_name }}
COACH_EMAIL={{ coach_email }}
COACH_PASSWORD={{ coach_password }}

# Anthropic (Claude)
ANTHROPIC_API_KEY={{ anthropic_api_key | default('') }}
ANTHROPIC_BASE_URL={{ anthropic_base_url | default('https://api.anthropic.com') }}
CLAUDE_MODEL={{ claude_model | default('claude-sonnet-4-20250514') }}

# SMTP
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port | default(587) }}
SMTP_USER={{ smtp_user }}
SMTP_PASS={{ smtp_pass }}
SMTP_FROM={{ smtp_from }}

# Server
PORT=3000
