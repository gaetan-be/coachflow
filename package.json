{
  "name": "brenso",
  "version": "1.0.0",
  "description": "Coaching orientation platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:client",
    "build:client": "cd client && npm run build",
    "start": "node dist/index.js",
    "deploy": "ansible-playbook -i ansible/inventory.ini ansible/deploy.yml",
    "report:dev": "npx ts-node src/scripts/dev-report.ts",
    "coaches:list": "npx ts-node src/scripts/list-coaches.ts",
    "dev": "concurrently \"tsc -w\" \"nodemon --watch dist dist/index.js\" \"cd client && npm run dev\"",
    "dev:server": "tsc -w & nodemon --watch dist dist/index.js",
    "dev:client": "cd client && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:db:start": "docker compose -f docker-compose.test.yml up -d postgres-test",
    "test:db:stop": "docker compose -f docker-compose.test.yml down"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
